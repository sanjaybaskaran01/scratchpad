{
  "name": "scratchpad",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test":          "vitest run",
    "test:watch":    "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e":      "playwright test",
    "test:e2e:ui":   "playwright test --ui",
    "test:all":      "vitest run && playwright test"
  },
  "devDependencies": {
    "@playwright/test":   "^1.44.0",
    "@vitest/coverage-v8": "^2.0.0",
    "fake-indexeddb":     "^5.0.0",
    "jsdom":              "^24.0.0",
    "lz-string":          "^1.5.0",
    "vitest":             "^2.0.0"
  }
}
